[Unit]
Description=Bluetooth Web Manager
After=bluetooth_2_usb.service network.target
Wants=network.target

[Service]
Type=idle
WorkingDirectory=/opt/bluetooth_2_usb/bt_web
ExecStartPre=/bin/sleep 5
ExecStart=/opt/bluetooth_2_usb/bt_web/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3
Nice=10

[Install]
WantedBy=multi-user.target
